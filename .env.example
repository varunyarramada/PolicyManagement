# ─────────────────────────────────────────────────
# PolicyManagement BFF — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────

# ── SQL Server ───────────────────────────────────
ConnectionStrings__DefaultConnection=Server=localhost,1433;Database=PolicyManagement;User Id=sa;Password=YourStrong@Passw0rd;TrustServerCertificate=true;

# ── JWT / Keycloak ───────────────────────────────
# Keycloak realm URL — must NOT end with a slash
Jwt__Authority=http://localhost:8080/realms/policy-management
# Client ID registered in Keycloak
Jwt__Audience=policy-management-api
# Set to false in local Docker; true in staging/production
Jwt__RequireHttpsMetadata=false

# ── Caching ──────────────────────────────────────
# TTL values in seconds
Cache__PolicyTtlSeconds=300
Cache__SummaryTtlSeconds=60

# ── Serilog ──────────────────────────────────────
Serilog__MinimumLevel__Default=Information
Serilog__MinimumLevel__Override__Microsoft=Warning
Serilog__MinimumLevel__Override__System=Warning

# ── Health Checks ────────────────────────────────
# Leave blank to use defaults
HealthChecks__SqlServerTimeout=5

# ── ASPNETCORE ───────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080

# ─────────────────────────────────────────────────────────────────────────────
# PolicyManagement BFF — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── SQL Server ───────────────────────────────────────────────────────────────
# SA (System Administrator) password for the SQL Server container.
# Must meet SQL Server complexity rules: min 8 chars, upper, lower, digit, symbol.
SA_PASSWORD=<your-strong-sa-password-here>

# Full ADO.NET connection string used by the BFF API container.
# Replace <your-strong-sa-password-here> with the same value as SA_PASSWORD above.
ConnectionStrings__DefaultConnection=Server=db,1433;Database=PolicyManagement;User Id=sa;Password=<your-strong-sa-password-here>;TrustServerCertificate=true;

# ── Keycloak admin credentials ────────────────────────────────────────────────
# Username for the Keycloak administrative console (http://localhost:8081).
KEYCLOAK_ADMIN=<keycloak-admin-username>
# Password for the Keycloak admin account.
KEYCLOAK_ADMIN_PASSWORD=<your-strong-keycloak-admin-password-here>

# ── JWT / Keycloak (informational — set directly in docker-compose.yml) ───────
# These are provided here for reference only. The API service in docker-compose
# uses the internal Docker network hostname "keycloak", not localhost.
# Keycloak realm URL — must NOT end with a slash.
Jwt__Authority=http://keycloak:8080/realms/policymanagement
# Client ID registered in Keycloak (must match realm-export.json).
Jwt__Audience=policymanagement-api
# Set to false in local Docker (Keycloak runs on HTTP); true in staging/production.
Jwt__RequireHttpsMetadata=false

# ── Caching ──────────────────────────────────────────────────────────────────
# TTL values in seconds
Cache__PolicyTtlSeconds=300
Cache__SummaryTtlSeconds=60

# ── Serilog ──────────────────────────────────────────────────────────────────
Serilog__MinimumLevel__Default=Information
Serilog__MinimumLevel__Override__Microsoft=Warning
Serilog__MinimumLevel__Override__System=Warning

# ── Health Checks ─────────────────────────────────────────────────────────────
# Leave blank to use defaults
HealthChecks__SqlServerTimeout=5

# ── ASPNETCORE ───────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080
